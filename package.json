{
  "name": "doctouche",
  "productName": "DocTouché!",
  "version": "1.0.0",
  "description": "Software di produzione documentale federale offline-first (Word+Excel+PowerPoint in uno, con normativa sportiva integrata)",
  "main": "src/main/main.js",
  "author": {
    "name": "Touché!Suite",
    "email": "touche-sw@outlook.it"
  },
  "license": "MIT",
  "scripts": {
    "build:renderer": "webpack --mode production",
    "start": "npm run build:renderer && electron .",
    "dist": "npm run build:renderer && electron-builder --win --mac --linux",
    "dist:win": "npm run build:renderer && electron-builder --win",
    "dist:mac": "npm run build:renderer && electron-builder --mac",
    "dist:linux": "npm run build:renderer && electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.33.9",
    "prosemirror-model": "^1.22.1",
    "prosemirror-schema-basic": "^1.2.3",
    "prosemirror-schema-list": "^1.4.1",
    "prosemirror-commands": "^1.6.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-tables": "^1.5.0",
    "prosemirror-transform": "^1.10.0",
    "docx": "^9.0.2",
    "jspdf": "^2.5.1",
    "html2canvas": "^1.4.1"
  },
  "build": {
    "appId": "it.touchesuite.doctouche",
    "productName": "DocTouché!",
    "directories": { "output": "release" },
    "files": ["src/**/*", "package.json"],
    "win": { "target": ["nsis"], "icon": "src/renderer/assets/icon.png" },
    "mac": { "target": ["dmg"], "icon": "src/renderer/assets/icon.png" },
    "linux": { "target": ["AppImage", "deb"], "icon": "src/renderer/assets/icon.png" }
  }
}
